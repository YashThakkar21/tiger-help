# Copy to .env and adjust. This is the only place the database connection is set;
# switching hosts (managed cloud, CS dept server, etc.) changes this one line.
DATABASE_URL="postgresql://USER@localhost:5432/tigerhelp_dev"

# --- Princeton CAS sign-in ---------------------------------------------------

# The public origin of this app. CAS compares this against the URL it was given
# at login and rejects a mismatch, so it must be exactly how you reach the site
# (scheme, host, port — no trailing slash).
APP_BASE_URL="http://localhost:3000"

# Signs the session cookie. Any value works locally; in production the app
# refuses to start without one, because whoever knows it can forge a session
# for any netID. Generate with:  openssl rand -base64 32
SESSION_SECRET="change-me-in-production-openssl-rand-base64-32"

# Princeton's CAS server. Only change this to point at a different CAS
# (a staging or departmental one) — the default is the real thing.
# CAS_BASE_URL="https://fed.princeton.edu/cas"

# Comma-separated netIDs promoted to ADMIN when they sign in. This is the way
# to create the FIRST admin, since there is no UI to appoint one yet. It only
# ever promotes, never demotes.
# BOOTSTRAP_ADMIN_NETIDS="yourNetid"

# Set to "off" to hide the dev sign-in shortcuts and test the real CAS flow in
# isolation. They are disabled in production regardless.
# DEV_IDENTITY_SWITCHER="off"

# --- Office hours calendar ---------------------------------------------------

# The Google Calendar shown on the Calendar tab. Paste whichever address you
# have — an embed link (?src=), a share link (?cid=), or a bare calendar id.
# Optional: the "Intro COS Lab" calendar is the built-in default, set in
# src/lib/calendar-embed.ts. Change this to point at a different calendar,
# e.g. for a new term.
#
# The calendar must be shared publicly, or the embed shows nothing to students.
# OFFICE_HOURS_CALENDAR="c_772442cccb1e3ec2e8e239a652f3ab420f70c03f4c91ba7f8a4706e11f6b62da@group.calendar.google.com"
