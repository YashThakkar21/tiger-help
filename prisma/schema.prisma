// TigerHelp data model — first cut: single global queue, filtered by course,
// ordered purely by signup time. Sessions/rooms/scheduling come later.
//
// Design principles (see design doc): boring, widely-known tech; the ticket_events
// log is append-only and is the source of truth for all future analytics.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Connection URL lives in prisma.config.ts (Prisma 7). See .env for DATABASE_URL.
}

// Global role for the first cut. The design doc scopes roles per-course, but a
// lab TA spans all three courses anyway, so a single role keeps auth simple until
// CAS + per-course rosters land. Swapping to per-course roles later is additive.
enum Role {
  STUDENT
  TA
  ADMIN
}

// How busy the queue felt during a shift, as judged by the TA who worked it.
// Three coarse buckets on purpose: a TA closing out at 10pm will answer three
// options honestly and a seven-point scale carelessly. This is the subjective
// counterpart to the demand the event log measures.
enum QueueBusyness {
  QUIET
  STEADY
  SLAMMED
}

enum TicketStatus {
  WAITING
  CLAIMED
  RESOLVED
  NO_SHOW
  LEFT
}

// Append-only event types — every state change is logged for analytics.
enum EventType {
  CREATED
  UPDATED
  CLAIMED
  RESOLVED
  REQUEUED
  NO_SHOW
  LEFT
}

// A scheduled shift's state. SCHEDULED = a TA owns it. OPEN = it's on the swap
// board because its TA can't make it (or it was never assigned), waiting for
// someone to cover.
enum ShiftSlotStatus {
  SCHEDULED
  OPEN
}

model User {
  id        String   @id @default(cuid())
  netid     String   @unique
  name      String
  email     String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticketsAsStudent Ticket[]      @relation("StudentTickets")
  ticketsClaimed   Ticket[]      @relation("ClaimedTickets")
  events           TicketEvent[]
  shifts           Shift[]
  scheduledShifts  ScheduledShift[] @relation("AssignedShifts")
  droppedShifts    ScheduledShift[] @relation("DroppedShifts")
}

// A planned shift on the schedule — distinct from `Shift`, which is the
// clock-in/out record of a stint actually worked. This is the design doc's
// §4.4 scheduling layer: head TAs lay out who covers which office-hours block,
// and TAs swap when they can't make one.
//
// The swap protocol is deliberately lightweight: a TA who can't make a shift
// drops it (status OPEN, assignedTo cleared, droppedBy remembered so the board
// can say who's out), and any other TA covers it (becomes assignedTo, back to
// SCHEDULED). No admin approval gate — coverage is the goal, and admins can see
// the whole schedule regardless.
model ScheduledShift {
  id       String          @id @default(cuid())
  startsAt DateTime
  endsAt   DateTime
  title    String // "COS126 Lab Hours"
  location String // room — every session is in person (design doc §4.1)
  status   ShiftSlotStatus @default(SCHEDULED)

  // The TA responsible right now. Null while the slot sits open on the board.
  assignedTo   User?   @relation("AssignedShifts", fields: [assignedToId], references: [id])
  assignedToId String?

  // Who put it up for swap — kept so the board can show "Grace is out", and
  // cleared once someone covers.
  droppedBy   User?   @relation("DroppedShifts", fields: [droppedById], references: [id])
  droppedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // "My upcoming shifts" and "what's open" are the two hot reads.
  @@index([assignedToId, startsAt])
  @@index([status, startsAt])
}

// A TA's stint on duty: the design doc's `shift_presence`, plus a short
// wrap-up written when they clock out.
//
// It answers two different questions. The timestamps say who was on duty when,
// which is what the load dashboard and the staffing heatmaps need. The notes
// say what actually happened — the recurring questions and snags a TA carries
// home in their head today and nobody ever sees again. Requiring a few
// sentences at clock-out is the cheapest way to capture that while it is still
// fresh, and it feeds the issue-intelligence work in §4.3.
//
// sessionId is absent for now: office-hours sessions don't exist yet, so a
// shift stands alone. Adding the link later is additive.
model Shift {
  id        String   @id @default(cuid())
  startedAt DateTime @default(now())
  endedAt   DateTime?

  // Both are required to END a shift, and null while one is open.
  notes    String?
  busyness QueueBusyness?

  ta   User   @relation(fields: [taId], references: [id])
  taId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // "Is this TA on shift?" and "who was on duty?" are the two hot reads.
  @@index([taId, startedAt])
  @@index([endedAt])
}

model Course {
  id        String   @id @default(cuid())
  code      String   @unique // "COS126"
  name      String
  createdAt DateTime @default(now())

  tickets Ticket[]
}

model Ticket {
  id          String       @id @default(cuid())
  status      TicketStatus @default(WAITING)
  assignment  String
  summary     String
  description String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  student   User   @relation("StudentTickets", fields: [studentId], references: [id])
  studentId String
  course    Course @relation(fields: [courseId], references: [id])
  courseId  String

  claimedBy   User?     @relation("ClaimedTickets", fields: [claimedById], references: [id])
  claimedById String?
  claimedAt   DateTime?

  resolvedAt     DateTime?
  resolutionNote String?

  // Requeue: a TA claimed but couldn't help, so the ticket goes back to WAITING
  // keeping its original createdAt (and therefore its FIFO place). We flag it so
  // a "requeued" tag can show next to the student.
  requeuedCount Int     @default(0)
  requeueReason String?

  // FIFO position at the moment a TA claimed (design doc: TAs may claim out of order,
  // and we record where in line the ticket was so admins can see it later).
  queuePositionAtClaim Int?

  events   TicketEvent[]
  feedback Feedback?

  @@index([status, createdAt])
  @@index([courseId, status, createdAt])
}

// Student feedback on the help they received. Admin-only by design: this is
// never returned by any TA-facing route (TAs cannot see their own ratings).
model Feedback {
  id        String   @id @default(cuid())
  rating    Int // 1–5
  comment   String?
  createdAt DateTime @default(now())

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String @unique
}

model TicketEvent {
  id        String    @id @default(cuid())
  type      EventType
  createdAt DateTime  @default(now())

  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId String

  actor   User?   @relation(fields: [actorId], references: [id])
  actorId String?

  queuePositionAtClaim Int?

  @@index([ticketId, createdAt])
}
